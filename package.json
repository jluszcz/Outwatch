{
    "name": "outwatch",
    "version": "1.0.0",
    "description": "Track which seasons of Survivor a small group has watched",
    "main": "src/index.js",
    "type": "module",
    "scripts": {
        "build": "node build.js",
        "dev": "concurrently -k -n bundle,worker -c cyan,magenta \"node build.js --watch\" \"wrangler dev\"",
        "deploy": "npm run build && wrangler deploy",
        "lint": "eslint .",
        "test": "vitest run",
        "test:watch": "vitest",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{js,css}": "prettier --write"
    },
    "author": "Jacob Luszcz",
    "license": "MIT",
    "engines": {
        "node": ">=20"
    },
    "overrides": {
        "undici": "^7.24.6",
        "picomatch": "^4.0.4"
    },
    "devDependencies": {
        "@cloudflare/vitest-pool-workers": "^0.16.20",
        "@cloudflare/workers-types": "^4.20260317.1",
        "@eslint/js": "^10.0.1",
        "concurrently": "^10.0.3",
        "esbuild": "^0.28.1",
        "eslint": "^10.6.0",
        "globals": "^17.7.0",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.8",
        "prettier": "^3.9.3",
        "vitest": "^4.1.5",
        "wrangler": "^4.75.0"
    },
    "dependencies": {
        "@hono/zod-validator": "^0.8.0",
        "hono": "^4.12.27",
        "htm": "^3.1.1",
        "preact": "^10.29.3",
        "zod": "^4.4.3"
    }
}
